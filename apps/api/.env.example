## API runtime
PHX_SERVER=true
PHX_HOST=localhost
PORT=4000
SECRET_KEY_BASE=replace_with_mix_phx_gen_secret
DNS_CLUSTER_QUERY=

## SurrealDB
SURREAL_URL=http://127.0.0.1:8000
SURREAL_NS=scout
SURREAL_DB=scoring
SURREAL_USER=root
SURREAL_PASS=root

## Auth/secrets
GUARDIAN_SECRET=replace_with_long_random_secret
STATION_TOKEN_SECRET=replace_with_long_random_secret

## AI import (POST /api/races/:id/ai-import/*)
## Required for the document → stations import feature. Uses the OpenAI
## Responses API; default model is gpt-5-mini. Override via OPENAI_MODEL.
OPENAI_API_KEY=sk-proj-1234567890
# OPENAI_MODEL=gpt-5-mini

## Seed task (mix scout.seed)
SEED_EMAIL=admin@example.com
SEED_PASS=changeme123
SEED_NAME=Admin